---
import BaseLayout from './BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { config } from '../lib/config';

interface Props {
  category: string;
  categoryName: string;
  description: string;
  articles: Array<{ id: string; data: any; body?: string }>;
}

const { category, categoryName, description, articles } = Astro.props;
---

<BaseLayout title={`${categoryName} — ${config.name}`} description={description}>
  <section class="py-12 px-4 max-w-7xl mx-auto">
    <div class="mb-10">
      <h1 class="text-3xl font-bold mb-3">{categoryName}</h1>
      <p class="text-gray-600">{description}</p>
    </div>

    {articles.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {articles.map((article) => (
          <ArticleCard
            title={article.data.title}
            slug={article.id}
            date={article.data.date}
            category={article.data.category}
            type={article.data.type}
            image={article.data.image}
            meta_description={article.data.meta_description}
          />
        ))}
      </div>
    ) : (
      <p class="text-gray-500 italic">Aucun article dans cette catégorie pour le moment.</p>
    )}
  </section>
</BaseLayout>
