---
interface Props {
  value: number;
  max?: number;
}

const { value, max = 10 } = Astro.props;

// Map value/max ratio to 5 stars
const ratio = Math.min(Math.max(value / max, 0), 1);
const filledStars = Math.round(ratio * 5);
const emptyStars = 5 - filledStars;
---

<span class="inline-flex items-center gap-2">
  <!-- Star icons -->
  <span class="flex items-center gap-0.5">
    {
      Array.from({ length: filledStars }).map(() => (
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5 text-yellow-400"
          viewBox="0 0 20 20"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      ))
    }
    {
      Array.from({ length: emptyStars }).map(() => (
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5 text-gray-300"
          viewBox="0 0 20 20"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      ))
    }
  </span>

  <!-- Numeric score -->
  <span class="text-lg font-bold text-gray-800" aria-label={`Note : ${value} sur ${max}`}>
    {value}
  </span>

  <!-- Suffix -->
  <span class="text-sm text-gray-400">/{max}</span>
</span>
